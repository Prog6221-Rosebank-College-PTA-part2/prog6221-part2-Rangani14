<Window x:Class="CyberSecurity2._0.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity2.0"
        Height="650"
        Width="950"
        Background="Black"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <Border Background="#111111"
                BorderBrush="Lime"
                BorderThickness="2"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,10">

            <StackPanel>

                <TextBlock Text="🔐 CyberSecurity2.0 🔐"
                           Foreground="Lime"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Stay Safe Online"
                           Foreground="Cyan"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- CHAT AREA -->
        <RichTextBox x:Name="ChatBox"
                     Grid.Row="1"
                     Background="#101010"
                     Foreground="Lime"
                     FontFamily="Consolas"
                     FontSize="15"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     BorderBrush="Cyan"
                     BorderThickness="2"
                     Margin="0,0,0,46"/>

        <!-- INPUT AREA -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UserInput"
                     Height="40"
                     FontSize="16"
                     FontFamily="Consolas"
                     Background="#202020"
                     Foreground="White"
                     BorderBrush="Lime"
                     BorderThickness="2"
                     Margin="0,0,10,0"/>

            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="SEND"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="DarkCyan"
                    Foreground="White"
                    Click="SendButton_Click" RenderTransformOrigin="0.326,-11.735" Margin="0,0,0,9">
                <Button.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="0.882"/>
                        <TranslateTransform X="5.841" Y="-0.276"/>
                    </TransformGroup>
                </Button.RenderTransform>
            </Button>
        </Grid>
    </Grid>
</Window>